-- allium: 3
-- host-lifecycle dream: the advisory memory-consolidation verdict over a project's
-- two memory stores. A dream run scans the repo MEMORY.md (append-only) and the
-- host-* per-user store (editable) for staleness, contradictions, drift, and
-- append-only violations, emits a per-finding route (edit on per-user store,
-- append on repo store), and settles to exactly one terminal verdict: clean (0),
-- findings (1), or error (2). It is read-only; the MCP memory_write tool is the
-- only mutator, and it refuses the repo store by construction.
--
-- Scope (post-weed-and-tend, 2026-07-19): the dream audit surface ONLY. The
-- MemoryWrite / Suggestion / LinkRef entities, the MCP-flavoured rules, and the
-- invariants that referenced them belong with the MCP layer (#extend-mcp) and
-- were restored there at that task. The dream-side surface here is: the detector
-- set, the routing rules, the verdict lifecycle, and the dream-relevant
-- invariants. Excludes: the stdio JSON-RPC transport (an implementation detail),
-- exact CLI flag names and output strings, and the cast/adversarial-review
-- rulings on detector naming (those feed back into the rule set before the
-- build, per plan/0073 gather-data).
--
-- Non-overlap (2026-07-19, recorded in plan/0073/gather-data.md): dream's
-- surface is memory-only. It never proposes a MADR supersession, an upgrade
-- application, or any other methodology-state change. Those are operator
-- actions on non-overlapping surfaces (MADR on call/, upgrade on the applied
-- set). A finding that traces to a superseded call/ names the record as
-- context, but the route stays edit/append on the memory.

-- The two memory stores plan/0073 audits. The asymmetry is load-bearing: the
-- repo store is append-only (CLAUDE.md section 6), the per-user store is
-- editable. The dream audit treats them differently; the memory_write MCP
-- tool refuses the repo store.
enum StoreLoc {
    repo
    per_user
}

-- The route a finding takes. The route is the operator-facing surface; the
-- detector class is secondary metadata. dream's surface is memory-only: edit
-- on the per-user store, append on the repo store. There is intentionally no
-- `madar` route and no third option; methodology-record actions are out of
-- dream's scope.
enum Route {
    edit
    append
}

-- A memory store: one repo store (the project's MEMORY.md) plus zero or more
-- per-user stores (the host-* per-user tier at ~/.host-memory/<project>/).
entity MemoryStore {
    loc: StoreLoc
}

-- One memory entry, in either store. The boolean fields carry the detector
-- preconditions directly (the allium idiom, mirroring host-lint's
-- `line.has_phase_synonym_numeral`): the dream analysis populates them from
-- the entry's content and the rest of the store, and the rule set fires when
-- they hold.
entity MemoryEntry {
    store: MemoryStore
    description: String
    body: String
    has_description_body_drift: Boolean
    is_superseded_unlinked: Boolean
    is_stale_state: Boolean
    is_workaround_not_plan: Boolean
    is_append_only_violation: Boolean
    is_room_touching: Boolean
    has_dangling_link: Boolean
}

-- A detected finding. Each finding carries its detector class and a route.
entity Finding {
    entry: MemoryEntry
    kind: String
    route: Route
}

-- One dream run. Starts scanning; the findings it accumulates drive the
-- terminal verdict. `saw_finding` records whether any detector fired;
-- `fix_mode` records whether --fix was passed. Single-shot: the given
-- `dream` is the only run in this universe; a future DreamStarts has no
-- effect once the run has left `dreaming`.
entity Dream {
    status: dreaming | clean | findings | error
    saw_finding: Boolean
    fix_mode: Boolean
    transitions status {
        dreaming -> clean
        dreaming -> findings
        dreaming -> error
        terminal: clean, findings, error
    }
}

given {
    dream: Dream
}

surface DreamRun {
    facing project: Project
    provides:
        DreamStarts(project)
        DreamCompletes(project)
        DreamFails(project)
}

-- === Project: shared with the wider host-lifecycle spec ===

entity Project {
    name: String
}

-- === Detectors (single-rule if/else form) ===
-- Each detector fires on a structural defect of an entry. Routing is encoded
-- at creation time via an if/else on the store: per-user -> edit, repo ->
-- append. One `requires` per detector means the store split cannot silently
-- eat a case (the failure mode the paired-detector form introduces), and
-- every invariant stays inductive (each creation rule checked once).

rule DetectDescriptionBodyDrift {
    when: entry: MemoryEntry.created
    requires: entry.has_description_body_drift
    ensures:
        if entry.store.loc = per_user:
            Finding.created(entry: entry, kind: "description-body-drift", route: edit)
        else:
            Finding.created(entry: entry, kind: "description-body-drift", route: append)
}

rule DetectSupersededButUnlinked {
    when: entry: MemoryEntry.created
    requires: entry.is_superseded_unlinked
    ensures:
        if entry.store.loc = per_user:
            Finding.created(entry: entry, kind: "superseded-but-unlinked", route: edit)
        else:
            Finding.created(entry: entry, kind: "superseded-but-unlinked", route: append)
}

rule DetectStaleStateOverLore {
    when: entry: MemoryEntry.created
    requires: entry.is_stale_state
    ensures:
        if entry.store.loc = per_user:
            Finding.created(entry: entry, kind: "stale-state-over-lore", route: edit)
        else:
            Finding.created(entry: entry, kind: "stale-state-over-lore", route: append)
}

rule DetectWorkaroundVsPlan {
    when: entry: MemoryEntry.created
    requires: entry.is_workaround_not_plan
    ensures:
        if entry.store.loc = per_user:
            Finding.created(entry: entry, kind: "workaround-vs-plan", route: edit)
        else:
            Finding.created(entry: entry, kind: "workaround-vs-plan", route: append)
}

rule DetectDanglingLink {
    when: entry: MemoryEntry.created
    requires: entry.has_dangling_link
    ensures:
        if entry.store.loc = per_user:
            Finding.created(entry: entry, kind: "dangling-link", route: edit)
        else:
            Finding.created(entry: entry, kind: "dangling-link", route: append)
}

-- Append-only violation: an in-place edit to an existing repo store entry. The
-- route is append: dream suggests a correcting append (the next entry that
-- supersedes the violated one, with a forward [[link]]). dream does not
-- propose a MADR record or any other methodology-state change.
rule DetectAppendOnlyViolation {
    when: entry: MemoryEntry.created
    requires: entry.is_append_only_violation and entry.store.loc = repo
    ensures: Finding.created(entry: entry, kind: "append-only-violation", route: append)
}

-- Room-touching finding: a memory entry that cites a call/ or plan/ record
-- since superseded by the spine. dream names the superseded record as context
-- in the finding text; the route is the memory edit (per-user) or append
-- (repo), never a MADR action. The named record itself is upgrade/MADR
-- territory, out of dream's scope.
rule DetectRoomTouching {
    when: entry: MemoryEntry.created
    requires: entry.is_room_touching
    ensures:
        if entry.store.loc = per_user:
            Finding.created(entry: entry, kind: "room-touching", route: edit)
        else:
            Finding.created(entry: entry, kind: "room-touching", route: append)
}

-- === Verdict lifecycle: findings drive the exit-code decision ===

-- StartDream inits the run: status -> dreaming, saw_finding -> false. The
-- init is what makes VerdictMatchesFindings provable: a stale `saw_finding`
-- latch from a prior run cannot leak in. fix_mode is bound at DreamStarts
-- (the CLI flag) and stays constant for the run.
rule StartDream {
    when: DreamStarts(project)
    ensures: dream.status = dreaming
    ensures: dream.saw_finding = false
}

-- RecordFinding is guarded on dreaming: a late Finding under a settled
-- verdict cannot flip the latch and produce a clean verdict that lied.
rule RecordFinding {
    when: finding: Finding.created
    requires: dream.status = dreaming
    ensures: dream.saw_finding = true
}

rule VerdictFindings {
    when: DreamCompletes(project)
    requires: dream.status = dreaming and dream.saw_finding
    ensures: dream.status = findings
}

rule VerdictClean {
    when: DreamCompletes(project)
    requires: dream.status = dreaming and not dream.saw_finding
    ensures: dream.status = clean
}

rule VerdictError {
    when: DreamFails(project)
    requires: dream.status = dreaming
    ensures: dream.status = error
}

-- === Invariants ===

-- A repo-store finding never routes to edit. Encoded at Finding creation time
-- via the if/else in each detector's ensures block. The Kani harness at
-- #write-tests proves `route_for(StoreLoc::Repo) == Route::Append` directly.
invariant RepoFindingsNeverEdit {
    for f in Findings where f.entry.store.loc = repo:
        f.route != edit
}

-- VerdictMatchesFindings: a clean verdict implies no finding was recorded. The
-- RecordFinding dreaming-guard and the StartDream saw_finding init together
-- make this provable. A clean verdict over a run that saw a finding is the
-- "verdict that lied" failure mode this invariant closes.
invariant VerdictMatchesFindings {
    for d in Dreams where d.status = clean:
        not d.saw_finding
}
